# =============================================================================
# Project Kganya environment template
# =============================================================================
# Copy the relevant values into Vercel production, preview, and local .env files.
# Do not commit real secrets here.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Main application connection string used by Prisma at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full&pgbouncer=true&connect_timeout=15"

# Direct / non-pooled connection string for Prisma CLI, seed, and migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full&connect_timeout=15"

# Optional fallbacks supported by the Prisma client helper in this repo.
DATABASE_URL_UNPOOLED=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_URL=

# -----------------------------------------------------------------------------
# Clerk authentication
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# -----------------------------------------------------------------------------
# Chatwoot webchat
# -----------------------------------------------------------------------------
# Website inbox token for the exact Chatwoot inbox you want the site to use.
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=
# Optional override for self-hosted Chatwoot; defaults to app.chatwoot.com.
NEXT_PUBLIC_CHATWOOT_BASE_URL=https://app.chatwoot.com

# -----------------------------------------------------------------------------
# Admin session fallback
# -----------------------------------------------------------------------------
# Required if you want the built-in admin session token flow to work.
BETTER_AUTH_SECRET=

# Optional: built-in admin password fallback for development or local recovery.
ADMIN_PASSWORD=
USER_LOGIN_PASSWORD=

# -----------------------------------------------------------------------------
# RBAC / bootstrap
# -----------------------------------------------------------------------------
# Comma-separated list of super admin email addresses.
RBAC_BOOTSTRAP_SUPER_ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# Kganya embedding bridge
# -----------------------------------------------------------------------------
# Optional: used by the Kganya embedding dispatch bridge.
KGANYA_EMBEDDING_WEBHOOK_URL=
KGANYA_EMBEDDING_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Dify sync
# -----------------------------------------------------------------------------
# Optional: only needed if you use Dify knowledge sync / document ingestion.
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_KB_API_KEY=
DIFY_DATASET_ID=
