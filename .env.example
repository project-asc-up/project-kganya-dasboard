# Recommended for most uses
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"

# For Prisma CLI commands and non-pooled migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&connect_timeout=15"

# Optional: used by the Kganya embedding dispatch bridge.
KGANYA_EMBEDDING_WEBHOOK_URL=
KGANYA_EMBEDDING_WEBHOOK_SECRET=

# Required for signing login sessions. Generate a strong random value per environment.
BETTER_AUTH_SECRET=

# Optional: only needed if you want to use the built-in administrator login.
ADMIN_PASSWORD=
