generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CoachLevel {
  UNDERGRADUATE
  POSTGRADUATE
  BOTH
  UNKNOWN
}

model Faculty {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  code            String       @unique
  codeStatus      String       @map("code_status")
  officialPageUrl String?      @map("official_page_url")
  supportPageUrl  String?      @map("support_page_url")
  sourceUrl       String?      @map("source_url")
  lastVerified    DateTime?    @map("last_verified") @db.Date
  notes           String?
  aliases         String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  ascCoaches      AscCoach[]
  programmes      Programme[]
  resources       Resource[]
  faqs            Faq[]

  @@index([name])
  @@map("faculties")
}

model AscCoach {
  id                 String      @id @default(uuid()) @db.Uuid
  facultyId          String      @map("faculty_id") @db.Uuid
  name               String
  titleRole          String?     @map("title_role")
  email              String
  phone              String?
  cell               String?
  officeLocation     String?     @map("office_location")
  building           String?
  appointmentLink    String?     @map("appointment_link")
  level              CoachLevel  @default(UNKNOWN)
  cluster            String?
  responsibilities   String?
  isActive           Boolean     @default(true) @map("is_active")
  sourceUrl          String?     @map("source_url")
  lastVerified       DateTime?   @map("last_verified") @db.Date
  verificationStatus String?     @map("verification_status")
  notes              String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  faculty            Faculty     @relation(fields: [facultyId], references: [id], onDelete: Restrict)

  @@unique([facultyId, email])
  @@index([facultyId])
  @@index([name])
  @@index([email])
  @@index([titleRole])
  @@index([cluster])
  @@map("asc_coaches")
}

model Programme {
  id                String         @id @default(uuid()) @db.Uuid
  facultyId         String         @map("faculty_id") @db.Uuid
  sourceFacultyCode String?        @map("source_faculty_code")
  programmeCode     String         @unique @map("programme_code")
  programmeName     String         @map("programme_name")
  degreeName        String?        @map("degree_name")
  academicLevel     String?        @map("academic_level")
  qualificationType String?        @map("qualification_type")
  programmeCredits  Int?           @map("programme_credits")
  durationYears     Int?           @map("duration_years")
  yearLevels        String?        @map("year_levels")
  sourceFile        String?        @map("source_file")
  lastVerified      DateTime?      @map("last_verified") @db.Date
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  faculty           Faculty        @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  courseModules     CourseModule[]

  @@index([facultyId])
  @@index([programmeName])
  @@index([facultyId, programmeName])
  @@map("programmes")
}

model CourseModule {
  id                String    @id @default(uuid()) @db.Uuid
  programmeId       String    @map("programme_id") @db.Uuid
  facultyCode       String?   @map("faculty_code")
  sourceFacultyCode String?   @map("source_faculty_code")
  programmeCode     String    @map("programme_code")
  programmeName     String?   @map("programme_name")
  yearLevelRaw      String    @map("year_level_raw")
  yearLevelSort     Int?      @map("year_level_sort")
  moduleCode        String    @map("module_code")
  moduleName        String?   @map("module_name")
  moduleType        String    @map("module_type")
  moduleUnits       Int       @map("module_units")
  sourceFile        String?   @map("source_file")
  lastVerified      DateTime? @map("last_verified") @db.Date
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  programme         Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@unique([programmeId, yearLevelRaw, moduleCode, moduleType, moduleUnits])
  @@index([programmeId])
  @@index([programmeCode])
  @@index([yearLevelSort])
  @@index([moduleCode])
  @@index([programmeCode, yearLevelSort, moduleCode])
  @@index([moduleName])
  @@map("courses_modules")
}

model Resource {
  id                 String    @id @default(uuid()) @db.Uuid
  seedKey            String    @unique @map("seed_key")
  facultyId          String?   @map("faculty_id") @db.Uuid
  resourceType       String    @default("link") @map("resource_type")
  category           String
  title              String
  description        String?
  url                String
  sourceUrl          String?   @map("source_url")
  lastVerified       DateTime? @map("last_verified") @db.Date
  notes              String?
  attachmentName     String?   @map("attachment_name")
  attachmentMimeType String?   @map("attachment_mime_type")
  attachmentSizeBytes Int?      @map("attachment_size_bytes")
  attachmentStatus   String?   @map("attachment_status")
  attachmentError    String?   @map("attachment_error")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  faculty            Faculty?  @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  @@index([facultyId])
  @@index([category])
  @@index([title])
  @@map("resources")
}

model DifySyncMap {
  sourceTable    String    @map("source_table")
  sourceId       String    @map("source_id")
  difyDocumentId String?   @map("dify_document_id")
  syncStatus     String    @default("pending") @map("sync_status")
  lastSyncedAt   DateTime? @map("last_synced_at") @db.Timestamptz(6)
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@id([sourceTable, sourceId])
  @@index([syncStatus])
  @@map("dify_sync_map")
}

model DifySyncJob {
  id             String    @id @default(uuid()) @db.Uuid
  sourceTable    String    @map("source_table")
  sourceId       String    @map("source_id")
  syncAction     String    @map("sync_action")
  contentKind    String    @map("content_kind")
  dedupeKey      String?   @map("dedupe_key")
  status         String    @default("pending")
  payload        Json?     @map("payload")
  attemptCount   Int       @default(0) @map("attempt_count")
  nextRetryAt    DateTime? @map("next_retry_at") @db.Timestamptz(6)
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([sourceTable, sourceId])
  @@index([syncAction])
  @@index([dedupeKey, status])
  @@map("dify_sync_jobs")
}

model MutationReceipt {
  id          String    @id @default(uuid()) @db.Uuid
  requestId   String    @unique @map("request_id")
  payloadHash String    @map("payload_hash")
  kind        String
  recordId    String?   @map("record_id")
  syncJobId   String?   @map("sync_job_id")
  status      String    @default("processing")
  result      Json?
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([recordId])
  @@map("mutation_receipts")
}

model Faq {
  id           String    @id @default(uuid()) @db.Uuid
  seedKey      String    @unique @map("seed_key")
  facultyId    String?   @map("faculty_id") @db.Uuid
  question     String
  answer       String
  category     String
  priority     Int?
  sourceUrl    String?   @map("source_url")
  lastVerified DateTime? @map("last_verified") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  faculty      Faculty?  @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  @@index([facultyId])
  @@index([category])
  @@index([priority])
  @@index([question])
  @@map("faqs")
}

model AuthUser {
  id             String    @id @default(uuid()) @db.Uuid
  universityId   String    @unique @map("university_id")
  passwordHash   String    @map("password_hash")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLoginAt    DateTime? @map("last_login_at")

  @@index([createdAt])
  @@map("auth_users")
}

model UserAccessAuditLog {
  id                  String   @id @default(uuid()) @db.Uuid
  actorUserId          String   @map("actor_user_id")
  actorEmail           String?  @map("actor_email")
  targetUserId         String   @map("target_user_id")
  targetEmail          String?  @map("target_email")
  previousRole         String   @map("previous_role")
  newRole              String   @map("new_role")
  previousPermissions  Json     @map("previous_permissions")
  newPermissions       Json     @map("new_permissions")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("user_access_audit_logs")
}

model RoleTabAccess {
  id        String   @id @default(uuid()) @db.Uuid
  role      String   // "admin" or "user"
  tab       String   // e.g. "/admin/faculties"
  isAllowed Boolean  @default(true) @map("is_allowed")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([role, tab])
  @@map("role_tab_access")
}

model UserTabAccess {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") // Clerk User ID
  tab       String   // e.g. "/admin/faculties"
  isAllowed Boolean  @map("is_allowed")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, tab])
  @@map("user_tab_access")
}
